<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Christian Reyes — UGC Creator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg: #0D0D0D;
  --surface: #151515;
  --surface2: #1E1E1E;
  --border: rgba(255,255,255,0.07);
  --text: #F0EDE8;
  --muted: rgba(240,237,232,0.45);
  --accent: #E8813A;
  --accent2: #4A9BAD;
  --gold: #C9A84C;
  --white: #FFFFFF;
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Outfit', sans-serif;
  font-weight: 400;
  overflow-x: hidden;
  line-height: 1.6;
}

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0 48px; height: 56px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(13,13,13,0.9); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav-brand {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px; letter-spacing: .12em; color: var(--text);
}
.nav-brand span { color: var(--accent); }
nav ul { display: flex; gap: 36px; list-style: none; }
nav a {
  font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  text-decoration: none; color: var(--muted); transition: color .25s;
}
nav a:hover { color: var(--text); }

/* HERO */
.hero {
  min-height: 100vh;
  display: grid; grid-template-columns: 1fr 1fr;
  padding-top: 56px;
}
.hero-left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 80px 56px; position: relative;
}
.hero-left::after {
  content: ''; position: absolute; right: 0; top: 10%; bottom: 10%;
  width: 1px; background: var(--border);
}
.hero-tag {
  font-size: 10px; letter-spacing: .3em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 20px;
  display: flex; align-items: center; gap: 10px;
}
.hero-tag::before {
  content: ''; width: 28px; height: 1px; background: var(--accent);
}
h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(72px, 9vw, 128px);
  line-height: .88; letter-spacing: .02em;
  margin-bottom: 24px;
}
h1 .line2 { color: var(--accent); }
.hero-bio {
  font-size: 15px; line-height: 1.8; color: var(--muted);
  max-width: 420px; margin-bottom: 40px;
  border-left: 2px solid var(--accent); padding-left: 18px;
}
.hero-bio strong { color: var(--text); font-weight: 500; }
.hero-stats { display: flex; gap: 40px; }
.hs-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px; letter-spacing: .04em;
  color: var(--text); line-height: 1;
}
.hs-label {
  font-size: 9px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--muted); margin-top: 3px;
}
.hero-right { position: relative; overflow: hidden; }
.hero-right img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 15%; display: block;
}
.hero-right::before {
  content: ''; position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(to right, var(--bg) 0%, transparent 30%);
}
.hero-handles { margin-top: 28px; display: flex; flex-wrap: wrap; gap: 10px; }
.handle-pill {
  font-size: 10px; letter-spacing: .12em;
  border: 1px solid var(--border);
  padding: 6px 14px; color: var(--muted);
  transition: all .25s;
}
.handle-pill:hover { border-color: var(--accent); color: var(--accent); }

/* SECTION BASE */
section { border-top: 1px solid var(--border); }
.wrap { max-width: 1200px; margin: 0 auto; padding: 80px 48px; }

.sec-label {
  font-size: 9px; letter-spacing: .3em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 12px; display: block;
}
.sec-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(36px, 5vw, 64px);
  letter-spacing: .04em; line-height: .95;
  margin-bottom: 32px;
}
.sec-title em { color: var(--accent); font-style: normal; }
.sec-body {
  font-size: 14px; line-height: 1.85; color: var(--muted); max-width: 600px;
}

/* WHO I AM */
.who-grid {
  display: grid; grid-template-columns: 1fr 1.5fr;
  gap: 64px; align-items: start;
}
.who-body { font-size: 14px; line-height: 1.9; color: var(--muted); }
.who-body p { margin-bottom: 16px; }
.who-body strong { color: var(--text); font-weight: 500; }
.who-body p:last-child { margin-bottom: 0; }

/* PHOTO SPLASH — editorial breaks between sections */
.photo-splash {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1px; background: var(--border);
  margin: 64px 0 0;
}
.photo-splash img {
  width: 100%; height: 420px; object-fit: cover; display: block;
  filter: brightness(.92);
  transition: filter .4s;
}
.photo-splash img:hover { filter: brightness(1); }
.photo-splash-full {
  width: 100%; height: 480px;
  background-size: cover; background-position: center;
  position: relative; overflow: hidden;
}
.photo-splash-full::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(13,13,13,0) 40%, rgba(13,13,13,.85) 100%);
}
.photo-splash-caption {
  position: absolute; bottom: 32px; left: 48px; z-index: 2;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px; letter-spacing: .06em; color: var(--text);
}
.photo-splash-caption em { color: var(--accent); font-style: normal; }

/* STYLES */
.styles-grid {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 1px; margin-top: 40px;
  background: var(--border);
}
.style-card {
  background: var(--surface);
  padding: 28px 24px;
  transition: background .3s;
  position: relative;
}
.style-card:hover { background: var(--surface2); }
.style-card::after {
  content: attr(data-num);
  position: absolute; top: 20px; right: 20px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px; color: rgba(255,255,255,.04);
  letter-spacing: .04em;
}
.sc-icon { font-size: 22px; margin-bottom: 14px; }
.sc-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px; letter-spacing: .06em;
  color: var(--text); margin-bottom: 8px;
}
.sc-desc { font-size: 12px; line-height: 1.7; color: var(--muted); }
.sc-fit {
  margin-top: 12px; font-size: 9px; letter-spacing: .14em;
  text-transform: uppercase; color: var(--accent); opacity: .8;
}

/* AUDIENCE */
.aud-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 64px; align-items: center;
}
.aud-list { list-style: none; margin-top: 32px; }
.aud-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 0; border-bottom: 1px solid var(--border);
}
.aud-k { font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted); }
.aud-v {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 17px; letter-spacing: .06em; color: var(--text);
}
.tag-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
.tag-chip {
  font-size: 9px; letter-spacing: .14em; text-transform: uppercase;
  border: 1px solid var(--border); padding: 5px 11px; color: var(--muted);
}

/* VIDEO REEL */
.reel-section { background: var(--surface); }
.reel-top {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 32px;
}
.reel-note { font-size: 11px; color: var(--muted); }
.vgrid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 3px;
}
.vi {
  position: relative; aspect-ratio: 9/16;
  overflow: hidden; background: #111; cursor: pointer;
}
.vi iframe {
  position: absolute; inset: 0; width: 100%; height: 100%;
  border: none; display: none;
}
.vcover { position: absolute; inset: 0; transition: opacity .3s; }
.vcover.gone { opacity: 0; pointer-events: none; }
.vcover img { width: 100%; height: 100%; object-fit: cover; display: block; }
.voverlay {
  position: absolute; inset: 0;
  background: rgba(13,13,13,.55);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 10px; transition: background .3s;
}
.vi:hover .voverlay { background: rgba(13,13,13,.3); }
.playbtn {
  width: 52px; height: 52px; border-radius: 50%;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  transition: transform .25s, background .25s;
  box-shadow: 0 4px 24px rgba(232,129,58,0.4);
}
.vi:hover .playbtn { transform: scale(1.12); background: #ff9550; }
.vlabel {
  font-size: 9px; letter-spacing: .16em; text-transform: uppercase;
  color: rgba(255,255,255,.85);
  background: rgba(0,0,0,.4); padding: 4px 10px;
}

/* PHOTO GALLERY — still work */
.stills-section { background: var(--bg); }
.stills-top {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 36px;
}
.photo-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 240px;
  gap: 3px;
}
.photo-tile {
  position: relative; overflow: hidden; background: #111;
}
.photo-tile.photo-portrait { grid-row: span 2; }
.photo-tile img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform .5s, filter .4s;
  filter: brightness(.9);
}
.photo-tile:hover img { transform: scale(1.05); filter: brightness(1); }
.photo-cap {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 16px 18px;
  background: linear-gradient(to top, rgba(0,0,0,.85), transparent);
  font-size: 10px; letter-spacing: .16em; text-transform: uppercase;
  color: var(--text); opacity: 0; transition: opacity .3s;
}
.photo-tile:hover .photo-cap { opacity: 1; }

/* BRANDS */
.logo-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; margin-top: 40px; background: var(--border);
}
.logo-tile {
  background: var(--surface); padding: 28px 20px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8px; min-height: 96px; transition: background .3s;
}
.logo-tile:hover { background: var(--surface2); }
.logo-tile img {
  max-width: 110px; max-height: 42px; object-fit: contain;
  filter: grayscale(100%) brightness(1.5);
  opacity: .55; transition: all .3s;
}
.logo-tile:hover img { filter: grayscale(0%) brightness(1); opacity: 1; }
.logo-cat {
  font-size: 8px; letter-spacing: .14em;
  text-transform: uppercase; color: var(--muted); text-align: center;
}

/* PRICING */
.pricing-section { background: var(--surface); }
.price-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1px; background: var(--border); margin-top: 36px;
}
.price-card { background: var(--surface2); padding: 32px 28px; }
.price-card.hot { background: var(--accent); }
.p-label {
  font-size: 9px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 12px; display: block;
}
.price-card.hot .p-label { color: rgba(255,255,255,.7); }
.p-amount {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 56px; letter-spacing: .02em; line-height: 1;
  color: var(--text);
}
.price-card.hot .p-amount { color: #fff; }
.p-sub { font-size: 11px; color: var(--muted); margin: 4px 0 20px; }
.price-card.hot .p-sub { color: rgba(255,255,255,.65); }
.p-list { list-style: none; display: flex; flex-direction: column; gap: 7px; }
.p-list li { font-size: 12px; color: var(--muted); display: flex; gap: 10px; }
.p-list li::before { content: '—'; color: var(--accent); flex-shrink: 0; }
.price-card.hot .p-list li { color: rgba(255,255,255,.75); }
.price-card.hot .p-list li::before { color: #fff; }

.wl-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--border); margin-top: 1px;
}
.wl-card { background: var(--surface2); padding: 24px 20px; }
.wl-card.gold { background: var(--gold); }
.wl-tier {
  font-size: 9px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 8px; display: block;
}
.wl-card.gold .wl-tier { color: rgba(13,13,13,.55); }
.wl-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 34px; letter-spacing: .04em;
  color: var(--text); line-height: 1;
}
.wl-card.gold .wl-price { color: var(--bg); }
.wl-period { font-size: 10px; color: var(--muted); margin: 3px 0 8px; }
.wl-card.gold .wl-period { color: rgba(13,13,13,.45); }
.wl-desc { font-size: 11px; color: var(--muted); line-height: 1.5; }
.wl-card.gold .wl-desc { color: rgba(13,13,13,.55); }

.addon-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1px; background: var(--border); margin-top: 1px;
}
.addon-card { background: var(--bg); padding: 22px 24px; }
.addon-label {
  font-size: 9px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 12px; display: block;
}
.addon-list { list-style: none; display: flex; flex-direction: column; gap: 7px; }
.addon-list li { font-size: 11px; color: var(--muted); display: flex; gap: 8px; }
.addon-list li::before { content: '—'; color: var(--accent); flex-shrink: 0; }

/* CONTACT */
.contact-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 72px; align-items: center;
}
.contact-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 7vw, 88px);
  letter-spacing: .04em; line-height: .9;
}
.contact-title em { color: var(--accent); font-style: normal; }
.contact-list { list-style: none; }
.contact-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 0; border-bottom: 1px solid var(--border);
}
.c-key { font-size: 9px; letter-spacing: .18em; text-transform: uppercase; color: var(--muted); }
.c-val {
  font-size: 13px; font-weight: 500; color: var(--text);
  text-decoration: none; transition: color .25s;
}
.c-val:hover { color: var(--accent); }
.best-fit {
  margin-top: 24px; padding: 24px;
  background: var(--surface); border: 1px solid var(--border);
}
.bf-label {
  font-size: 9px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 8px;
}
.bf-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 16px; letter-spacing: .08em;
  color: var(--muted); line-height: 1.6;
}

/* FOOTER */
footer {
  border-top: 1px solid var(--border);
  padding: 20px 48px;
  display: flex; justify-content: space-between; align-items: center;
}
.foot-l { font-size: 10px; letter-spacing: .12em; color: var(--muted); }
.foot-r {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 14px; letter-spacing: .12em; color: var(--muted);
}

/* REVEAL */
.rev { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
.rev.on { opacity: 1; transform: none; }

/* RESPONSIVE */
@media (max-width: 900px) {
  nav { padding: 0 20px; }
  nav ul { display: none; }
  .hero { grid-template-columns: 1fr; }
  .hero-right { height: 60vw; }
  .hero-left { padding: 80px 24px 48px; }
  .wrap { padding: 56px 24px; }
  .who-grid, .aud-grid, .contact-grid { grid-template-columns: 1fr; gap: 36px; }
  .styles-grid { grid-template-columns: 1fr 1fr; }
  .logo-grid { grid-template-columns: repeat(2, 1fr); }
  .vgrid { grid-template-columns: repeat(2, 1fr); }
  .price-grid, .addon-grid { grid-template-columns: 1fr; }
  .wl-grid { grid-template-columns: repeat(2, 1fr); }
  .photo-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
  .photo-splash { grid-template-columns: 1fr; }
  .photo-splash img { height: 280px; }
  footer { padding: 18px 24px; flex-direction: column; gap: 8px; }
}
</style>
</head>
